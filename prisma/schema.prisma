// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  role          String    @default("VOLUNTEER") // "MASTER_ADMIN", "VOLUNTEER"
  profileImage  String?
  status        String    @default("ACTIVE") // "ACTIVE", "INACTIVE"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs     AuditLog[]
  verifiedDonations Donation[] @relation("VerifiedBy")
}

model Student {
  id            String    @id @default(cuid())
  federationId  String    @unique // VSF-YYYY-SCH-XXXX
  fullName      String
  mobileNumber  String
  email         String?
  fatherName    String?
  motherName    String?
  parentContact String?
  aadhaarNumber String?   @unique
  dob               String?
  permanentAddress  String?
  currentAddress    String?
  bloodGroup        String?
  class             String?
  batch             String?
  joiningYear       Int
  donationStartDate DateTime?
  duesAmount        Float     @default(0)
  lastSchool        String?
  specialization    String?
  bio               String?
  workingAt         String?
  role          String    @default("STUDENT") // "STUDENT", "ALUMNI"
  profileImage  String?
  idProofImage  String?
  status        String    @default("ACTIVE") // "ACTIVE", "ALUMNI", "INACTIVE", "PENDING_APPROVAL"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  donations     Donation[]
  receipts      Receipt[]

  deletedAt     DateTime?
}

model Donation {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id])
  amount        Float
  type          String    @default("MONTHLY") // "MONTHLY", "ADVANCE", "CUSTOM"
  startMonth    Int?      // 1-12
  endMonth      Int?      // 1-12
  startYear     Int?
  endYear       Int?
  status        String    @default("PENDING") // "PENDING", "PAID", "REJECTED", "OVERDUE", "PARTIAL"
  paymentMethod String?   // "CASH", "UPI", "BANK_TRANSFER"
  paymentProof  String?   // Cloudinary URL or Base64
  notes         String?   // Cash taker name or remarks
  
  verifiedById  String?
  verifiedBy    User?     @relation("VerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt    DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  deletedAt     DateTime?

  receipt       Receipt?
}

model Receipt {
  id            String    @id @default(cuid())
  receiptNumber String    @unique // VSF-REC-YYYY-XXXXX
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id])
  donationId    String    @unique
  donation      Donation  @relation(fields: [donationId], references: [id])
  amount        Float
  date          DateTime  @default(now())
  pdfUrl        String?   // Cloudinary URL of the generated PDF
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Expense {
  id            String    @id @default(cuid())
  title         String
  amount        Float
  category      String    // "EVENT", "STATIONARY", "BOOKS", "EMERGENCY", "WELFARE", "MISC"
  description   String?
  billImage     String?   // Cloudinary URL
  date          DateTime  @default(now())
  status        String    @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  
  deletedAt     DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Announcement {
  id            String    @id @default(cuid())
  title         String
  content       String
  targetRole    String    @default("ALL") // "ALL", "STUDENT", "VOLUNTEER"
  
  deletedAt     DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AuditLog {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  action        String    // e.g., "DONATION_VERIFIED", "STUDENT_ADDED"
  entityType    String    // e.g., "DONATION", "STUDENT"
  entityId      String
  details       String?
  
  createdAt     DateTime  @default(now())
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model SupportRequest {
  id           String   @id @default(cuid())
  fullName     String
  email        String
  mobileNumber String
  studentId    String?
  supportType  String   // "EDUCATIONAL", "FINANCIAL", "WELFARE", "EMERGENCY", "OTHER"
  description  String
  attachmentUrl String?  // Base64 or Cloudinary URL
  attachmentName String?
  status       String   @default("PENDING") // "PENDING", "REVIEWED", "RESOLVED"
  adminNote    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

